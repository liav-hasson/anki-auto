# Copy this file to `.env` and fill in your values: `cp examples/.env.example .env`

# --- Required variables ---

# OpenAI API key used for card and audio generation.
OPENAI_API_KEY=

# Language for the front of the card.
ANKI_ORIGIN_LANGUAGE=Spanish
# Language on the back of the card.
ANKI_TARGET_LANGUAGE=French
# Language for note content.
ANKI_NOTES_LANGUAGE=English

# Your CEFR Level - one of: A1 A2 B1 B2 C1 C2
ANKI_CEFR_LEVEL=A2

# --- Optional variables ---

ANKI_TEXT_MODEL=gpt-4.1-mini

# Optional: reasoning effort for reasoning-capable models (e.g. gpt-5.5).
# Leave unset — the default model (gpt-4.1-mini) is non-reasoning and will error if this is set.
# Accepted values are model-dependent: none, minimal, low, medium, high, xhigh, max.
# ANKI_REASONING_EFFORT=medium

ANKI_AUDIO_MODEL=gpt-4o-mini-tts
ANKI_AUDIO_VOICE=alloy
ANKI_DECK_NAME=Anki Auto Deck
ANKI_INPUT_PATH=items.txt
ANKI_OUTPUT_PATH=deck.apkg

# Optional free-form generation instructions; missing/empty files warn and are skipped.
ANKI_CUSTOMIZATION_PATH=customization.txt
# Optional target-language vocabulary exclusions; enforcement is best effort.
ANKI_BLACKLIST_PATH=blacklist.txt

# --- Performance ---

# Number of parallel OpenAI requests (>=1); higher = faster but watch rate limits.
ANKI_CONCURRENCY=5

# --- Toggles ---

# true = generate audio for each main example sentence.
ANKI_GENERATE_AUDIO=true
# true = sentences only (core + examples, no notes).
ANKI_MINIMAL_CARDS=false
# true = skip the confirmation prompt (for automation/non-interactive use)
ANKI_ASSUME_YES=false
# true = overwrite an existing output file instead of writing <name>_1.apkg
ANKI_OVERWRITE_OUTPUT=false
